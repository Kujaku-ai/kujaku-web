---
// Left identity spine. Fixed-position 220px column to the right of the
// global nav-rail, anchored under the masthead. Top-to-bottom: sector
// eyebrow, italic name, mono symbol, source/status/updated table,
// hairline, intraday sparkline, foot.
//
// Phase 2: sparkline is a real LWC chart from MOCK bars. Whatever the
// asset has in `data.bars` (60 for BTC, fewer for some quantum tickers)
// is sliced to the last 30 closes and shipped into SpineSparkline.

import SpineSparkline from '~/components/shell/SpineSparkline.astro';
import type { Bar } from '~/lib/types/asset';
import type { TfPoint } from '~/lib/data/mock';

export interface Props {
  sector: string;             // display label, e.g. 'Crypto'
  fullName: string;
  symbol: string;
  sourceLabel: string;
  status: 'live' | 'stale' | 'down';
  lastUpdatedISO: string;
  bars: Bar[];                // recent OHLC bars (sliced to 30 closes)
}

const { sector, fullName, symbol, sourceLabel, status, lastUpdatedISO, bars } = Astro.props;

function fmtUtc(iso: string): string {
  const d = new Date(iso);
  const h = String(d.getUTCHours()).padStart(2, '0');
  const m = String(d.getUTCMinutes()).padStart(2, '0');
  return `${h}:${m} UTC`;
}

const statusLabel = status === 'live' ? 'LIVE' : status === 'stale' ? 'STALE' : 'DOWN';
const updated = fmtUtc(lastUpdatedISO);

// Last-30 closes as LWC line points. Quantum tickers with fewer than
// 30 bars degrade gracefully — SpineSparkline renders whatever we
// have (or skips the chart for <2 points).
const sparkSeries: TfPoint[] = bars.slice(-30).map((b) => ({
  time: b.time,
  value: b.close,
}));
---

<aside class="spine" aria-label="ticker identity">
  <div class="spine-head">
    <p class="spine-sector">{sector.toUpperCase()}</p>
    {/* Page-level h1 lives here at ≥1100px. AssetPage adds a
        visually-hidden h1 fallback so the asset name is announced
        on mobile too (the spine itself is display:none below 1100). */}
    <h1 class="spine-name">{fullName}</h1>
    <p class="spine-sym">{symbol}</p>
  </div>
  <div class="spine-status">
    <div class="row"><span>source</span><span class="v">{sourceLabel}</span></div>
    <div class={`row${status === 'stale' ? ' is-stale' : ''}`}>
      <span>status</span><span class="v">{statusLabel}</span>
    </div>
    <div class="row"><span>updated</span><span class="v">{updated}</span></div>
  </div>
  <div class="spine-sparkline">
    <p class="sp-label">intraday · 30 bar</p>
    <SpineSparkline series={sparkSeries} />
  </div>
  <p class="spine-foot">kujaku.ai</p>
</aside>

<style>
  .spine {
    position: fixed;
    top: var(--masthead-height);
    left: var(--rail-collapsed);
    width: var(--spine-width);
    height: calc(100vh - var(--masthead-height));
    overflow-y: auto;
    box-sizing: border-box;
    padding: 28px 22px;
    border-right: 1px solid var(--ink-faint);
    background: var(--paper);
    display: flex; flex-direction: column; gap: 26px;
    z-index: 1;
  }
  .spine-head {
    display: flex; flex-direction: column; gap: 12px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--ink-faint);
  }
  .spine-sector {
    font-family: var(--font-mono); font-size: 9px; font-weight: 500;
    letter-spacing: 0.28em; text-transform: uppercase;
    /* a11y: promoted from --ink-pale for sub-18px contrast on --paper. */
    color: var(--ink-mid); margin: 0;
  }
  .spine-name {
    font-family: var(--font-display); font-style: italic; font-weight: 300;
    font-size: 30px; line-height: 1; letter-spacing: -0.02em;
    color: var(--ink); margin: 0;
  }
  .spine-sym {
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--ink); margin: 0;
    font-variant-numeric: tabular-nums;
  }
  .spine-status {
    display: flex; flex-direction: column; gap: 8px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--ink-faint);
    font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-mid);
  }
  .spine-status .row {
    display: flex; justify-content: space-between; align-items: baseline;
  }
  .spine-status .row .v {
    color: var(--ink); font-variant-numeric: tabular-nums;
  }
  .spine-status .row.is-stale .v { color: var(--ink); font-weight: 500; }

  .spine-sparkline {
    display: flex; flex-direction: column; gap: 10px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--ink-faint);
  }
  .spine-sparkline .sp-label {
    font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.22em; text-transform: uppercase;
    /* a11y: promoted from --ink-pale for sub-18px contrast on --paper. */
    color: var(--ink-mid); margin: 0;
  }

  .spine-foot {
    margin: auto 0 0;
    font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.22em; text-transform: uppercase;
    /* a11y: promoted from --ink-pale for sub-18px contrast on --paper. */
    color: var(--ink-mid);
  }

  @media (max-width: 1100px) {
    .spine { display: none; }
  }
</style>
