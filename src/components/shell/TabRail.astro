---
// 5-tab pressed-paper segmented control. Anchor-based for Phase 1 — the
// dynamic `[tab].astro` route handles the swap server-side, so no client
// JS is needed. Phase 5+ may add sessionStorage-backed soft-navigation,
// but that's out of scope here.

import { ASSET_TABS, type AssetTab } from '~/lib/types/asset';

export interface Props {
  sectorSlug: string;
  assetSlug: string;
  activeTab: AssetTab;
}

const { sectorSlug, assetSlug, activeTab } = Astro.props;

const TAB_LABELS: Record<AssetTab, string> = {
  overview: 'Overview',
  charting: 'Charting',
  agents: 'Agents',
  news: 'News',
  comparisons: 'Comparisons',
};
---

<nav class="tab-bar" aria-label="binder pages">
  {/* Plain anchor nav, NOT role="tablist" — the tabs trigger full
      route navigation (server re-renders the tab content), not in-
      page tab-panel switching. ARIA tablist semantics expect
      arrow-key navigation between tabs, which would conflict with
      anchor-default Tab cycling. aria-current="page" carries the
      "active" state instead of aria-selected. */}
  {ASSET_TABS.map((tab) => (
    <a
      href={`/${sectorSlug}/${assetSlug}/${tab}`}
      class={tab === activeTab ? 'is-active' : ''}
      aria-current={tab === activeTab ? 'page' : undefined}
      data-page={tab}
    >{TAB_LABELS[tab]}</a>
  ))}
</nav>

<style>
  .tab-bar {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    margin: 0 0 22px;
  }
  .tab-bar a {
    flex: 1 1 0;
    min-width: 110px;
    padding: 12px 14px;
    background: var(--paper);
    border: 0;
    border-radius: 2px;
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase;
    /* a11y: promoted from --ink-mid (4.0 contrast on --paper, fails
       AA at sub-18px) to --ink-soft (8.1). Phase 7's contrast pass
       missed this case because the rule was framed as "ink-pale →
       ink-mid"; ink-mid was already the start state here. */
    color: var(--ink-soft);
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: box-shadow 240ms var(--ease-out),
                background 240ms var(--ease-out),
                color 240ms var(--ease-out);
    box-shadow:
      inset 0 1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.5),
      0 2px 6px rgba(40,30,18,0.05),
      0 6px 14px rgba(40,30,18,0.04);
  }
  .tab-bar a:hover { color: var(--ink); }
  .tab-bar a.is-active {
    background: var(--paper-deep);
    color: var(--ink);
    font-weight: 500;
    box-shadow:
      inset 0 2px 4px rgba(40,30,18,0.10),
      inset 0 -1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.7);
  }

  @media (max-width: 700px) {
    .tab-bar { flex-wrap: wrap; gap: 6px; }
    .tab-bar a {
      min-width: calc(50% - 3px);
      padding: 10px 8px;
      font-size: 9px;
      letter-spacing: 0.16em;
    }
  }
</style>
