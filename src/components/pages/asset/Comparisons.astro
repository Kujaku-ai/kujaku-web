---
// Comparisons tab — page header + stack of ComparisonCards + closing
// ComparisonSlot.
//
// Slot ALWAYS renders at the end, even when comparisons.length > 0
// (matches v02 behavior — encourages adding more). When the list is
// empty, an extra mono empty-state line precedes the slot.
//
// All four tickers carry ≥1 comparison in the current mock, so the
// empty-state branch isn't exercised at runtime; it's still in
// place for the live-data scenario in Phase 8+ where a freshly
// added ticker may have no comparisons yet.

import type { AssetData } from '~/lib/types/asset';
import ComparisonCard from '~/components/tiles/ComparisonCard.astro';
import ComparisonSlot from '~/components/tiles/ComparisonSlot.astro';

export interface Props { data: AssetData }
const { data } = Astro.props;

const comps = data.comparisons;
const metaLine = comps.length > 0
  ? `比較 · ${comps.length} active · agentic reports refresh daily`
  : `比較 · build your own — agentic reports refresh daily`;
---

<section class="comparisons-page">
  <header class="page-head">
    <h2 class="page-title">Comparisons · {data.fullName}</h2>
    <p class="page-meta">{metaLine}</p>
  </header>

  <div class="cm-stack">
    {comps.length === 0 && (
      <p class="cm-empty">
        no comparisons yet for {data.symbol} · build your first below
      </p>
    )}

    {comps.map((c) => (
      <ComparisonCard
        comparison={c}
        selfSymbol={data.symbol}
        selfName={data.fullName}
        selfPrice={data.currentPrice}
      />
    ))}

    <ComparisonSlot fullName={data.fullName} />
  </div>
</section>

<style>
  .comparisons-page {
    display: flex; flex-direction: column;
    gap: 22px;
  }

  .page-head {
    display: flex; flex-wrap: wrap; align-items: baseline;
    justify-content: space-between; gap: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--ink-faint);
  }
  .page-title {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: 28px; line-height: 1.1; letter-spacing: -0.01em;
    color: var(--ink); margin: 0;
  }
  /* The meta line embeds 比較 (hikaku) as raw text — the brand JP
     font kicks in on the kanji glyph naturally; no need for a span. */
  .page-meta {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    /* a11y: promoted from --ink-mid for sub-18px contrast on
       --paper-deep (page bg). */
    color: var(--ink-soft); margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .cm-stack {
    display: flex; flex-direction: column;
    gap: 18px;
  }

  .cm-empty {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    /* a11y: promoted from --ink-pale for sub-18px contrast on
       --paper-deep (page bg). */
    color: var(--ink-soft); margin: 0;
    padding: 32px 0; text-align: center;
  }

  @media (max-width: 700px) {
    .comparisons-page { gap: 18px; }
    .page-title { font-size: 22px; }
    .cm-stack { gap: 14px; }
  }
</style>
