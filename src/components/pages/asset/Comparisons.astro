---
import type { AssetData } from '~/lib/types/asset';

export interface Props { data: AssetData }
const { data } = Astro.props;
---

<section class="phase1-stub">
  <p class="eyebrow">phase 6 · comparison <span class="jp">比較</span></p>
  <h2 class="title">Comparisons — {data.fullName}</h2>
  <p class="body">
    Stack of editorial comparison cards (vs hero row, key-metric callout,
    italic title, agentic synthesis prose, dark CTA) plus a sunken
    build-your-own slot. {data.comparisons.length} active comparison{data.comparisons.length === 1 ? '' : 's'} · agentic reports refresh daily.
  </p>
</section>

<style>
  .phase1-stub {
    padding: 36px 32px 40px;
    background: var(--paper);
    border-radius: 4px;
    box-shadow:
      inset 0 1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.5),
      0 4px 12px rgba(40,30,18,0.05);
  }
  .eyebrow {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--red); margin: 0 0 14px;
    display: inline-flex; align-items: baseline; gap: 10px;
  }
  .eyebrow .jp {
    font-family: var(--font-jp); font-size: 13px;
    letter-spacing: 0.04em; text-transform: none;
    color: var(--red); font-weight: 400;
  }
  .title {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: 28px; line-height: 1.1; letter-spacing: -0.01em;
    color: var(--ink); margin: 0 0 14px;
  }
  .body {
    font-family: var(--font-body); font-size: 14px; line-height: 1.6;
    color: var(--ink-mid); margin: 0; max-width: 64ch;
  }
</style>
