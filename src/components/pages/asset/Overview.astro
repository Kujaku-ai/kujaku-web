---
// Overview tab — full content. 5fr/7fr two-column grid at desktop,
// stack at ≤1100px. Mock data only in Phase 2.
//
// Left column (5fr): hero · perf+bias · activity feed (stacked).
// Right column (7fr): mini chart tile (LWC, TF buttons).

import type { AssetData } from '~/lib/types/asset';
import OverviewHero from '~/components/tiles/OverviewHero.astro';
import PerfBiasCard from '~/components/tiles/PerfBiasCard.astro';
import RecentActivityFeed from '~/components/tiles/RecentActivityFeed.astro';
import OverviewMiniChart from '~/components/tiles/OverviewMiniChart.astro';

export interface Props { data: AssetData }
const { data } = Astro.props;

// Path bases for "see more" links in the tiles.
const sectorSlug = data.sector === 'crypto' ? 'crypto' : 'qc';
const newsHref = `/${sectorSlug}/${data.slug}/news`;
const chartingHref = `/${sectorSlug}/${data.slug}/charting`;
---

<div class="overview-grid">
  <div class="left-col">
    <OverviewHero data={data} />
    <PerfBiasCard data={data} />
    <RecentActivityFeed data={data} newsHref={newsHref} />
  </div>
  <div class="right-col">
    <OverviewMiniChart data={data} moreHref={chartingHref} />
  </div>
</div>

<style>
  .overview-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 18px;
    align-items: start;
  }
  .left-col,
  .right-col {
    display: flex; flex-direction: column; gap: 18px;
    min-width: 0;
  }
  /* Mini chart should fill the right column visually so the grid feels
     anchored even when the left column is taller. */
  .right-col { align-self: stretch; }

  @media (max-width: 1100px) {
    .overview-grid { grid-template-columns: 1fr; gap: 16px; }
    .left-col, .right-col { gap: 16px; }
  }
  @media (max-width: 700px) {
    .overview-grid { gap: 14px; }
    .left-col, .right-col { gap: 14px; }
  }
</style>
