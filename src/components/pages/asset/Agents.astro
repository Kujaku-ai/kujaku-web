---
// Agents tab — page header + stack of AgentCards + closing AgentSlot.
//
// BTC: 1 AgentCard (kalshi 15-min) + AgentSlot variant="add"
// Quantum tickers: 0 cards + AgentSlot variant="empty"

import type { AssetData } from '~/lib/types/asset';
import AgentCard from '~/components/tiles/AgentCard.astro';
import AgentSlot from '~/components/tiles/AgentSlot.astro';

export interface Props { data: AssetData }
const { data } = Astro.props;

const agents = data.agents;
const deployed = agents.length;
const slotVariant: 'add' | 'empty' = deployed > 0 ? 'add' : 'empty';
---

<section class="agents-page">
  <header class="page-head">
    <h2 class="page-title">
      Analysts · {data.fullName}
      <span class="jp" aria-hidden="true">分析者</span>
    </h2>
    <p class="page-meta">
      {deployed} deployed · 0 pending
    </p>
  </header>

  <div class="agents-stack">
    {agents.map((agent) => (
      <AgentCard agent={agent} />
    ))}
    <AgentSlot variant={slotVariant} fullName={data.fullName} />
  </div>
</section>

<style>
  .agents-page {
    display: flex; flex-direction: column;
    gap: 22px;
  }

  .page-head {
    display: flex; flex-wrap: wrap; align-items: baseline;
    justify-content: space-between; gap: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--ink-faint);
  }
  .page-title {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: 28px; line-height: 1.1; letter-spacing: -0.01em;
    color: var(--ink); margin: 0;
    display: inline-flex; align-items: baseline; gap: 14px;
  }
  .page-title .jp {
    font-family: var(--font-jp); font-size: 18px;
    letter-spacing: 0.04em; color: var(--red);
    font-style: normal;
  }
  .page-meta {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    /* a11y: promoted from --ink-mid for sub-18px contrast on
       --paper-deep (page bg). */
    color: var(--ink-soft); margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .agents-stack {
    display: flex; flex-direction: column;
    gap: 18px;
  }

  @media (max-width: 700px) {
    .agents-page { gap: 18px; }
    .page-title { font-size: 24px; }
    .page-title .jp { font-size: 16px; }
    .agents-stack { gap: 14px; }
  }
</style>
