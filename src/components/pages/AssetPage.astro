---
import Base from '~/layouts/Base.astro';
import IdentitySpine from '~/components/shell/IdentitySpine.astro';
import Masthead from '~/components/shell/Masthead.astro';
import TabRail from '~/components/shell/TabRail.astro';
import Overview from '~/components/pages/asset/Overview.astro';
import Charting from '~/components/pages/asset/Charting.astro';
import Agents from '~/components/pages/asset/Agents.astro';
import News from '~/components/pages/asset/News.astro';
import Comparisons from '~/components/pages/asset/Comparisons.astro';
import { sectorBySlug, assetBySlug } from '~/config/taxonomy';
import { loadAssetData } from '~/lib/data/mock';
import type { AssetTab } from '~/lib/types/asset';

export interface Props {
  sectorSlug: string;
  assetSlug: string;
  activeTab: AssetTab;
}

const { sectorSlug, assetSlug, activeTab } = Astro.props;

const sector = sectorBySlug(sectorSlug);
const asset = assetBySlug(assetSlug);
const data = loadAssetData(assetSlug);

// Caller route validates these before invoking; defensive null check
// here keeps the type system honest.
if (!sector || !asset || !data) {
  return new Response('Not found', { status: 404 });
}

function fmtStamp(iso: string): string {
  const d = new Date(iso);
  const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const day = d.getUTCDate();
  const mon = months[d.getUTCMonth()];
  const h = String(d.getUTCHours()).padStart(2, '0');
  const m = String(d.getUTCMinutes()).padStart(2, '0');
  return `${day} ${mon} · ${h}:${m} UTC · ${data.sourceLabel.toUpperCase()}`;
}

const stamp = fmtStamp(data.lastUpdated);

const TAB_LABELS: Record<AssetTab, string> = {
  overview: 'Overview',
  charting: 'Charting',
  agents: 'Agents',
  news: 'News',
  comparisons: 'Comparisons',
};
---

<Base title={`kujaku.ai — ${data.fullName} · ${TAB_LABELS[activeTab]}`}>
  <div class="binder">
    <IdentitySpine
      sector={sector.name}
      fullName={data.fullName}
      symbol={data.symbol}
      sourceLabel={data.sourceLabel}
      status={data.stale ? 'stale' : 'live'}
      lastUpdatedISO={data.lastUpdated}
      bars={data.bars}
    />

    <main class="content">
      {/* Mobile h1 fallback. The spine carries the canonical h1 at
          ≥1100px; below that the spine is display:none and its h1 is
          gone from the accessibility tree, so we expose this one
          there. The CSS toggles whichever is active by viewport so
          screen readers see exactly one h1 either way. */}
      <h1 class="mobile-h1-fallback">{data.fullName}</h1>

      <Masthead
        sectorName={sector.name}
        fullName={data.fullName}
        stamp={stamp}
      />

      <TabRail
        sectorSlug={sector.slug}
        assetSlug={asset.slug}
        activeTab={activeTab}
      />

      {data.stale && (
        <div class="stale-banner">
          <span class="label">status · stalled</span>
          <span class="detail">last update {data.lastUpdated}</span>
        </div>
      )}

      <section class="page is-active" data-page={activeTab}>
        {activeTab === 'overview' && <Overview data={data} />}
        {activeTab === 'charting' && <Charting data={data} />}
        {activeTab === 'agents' && <Agents data={data} />}
        {activeTab === 'news' && <News data={data} />}
        {activeTab === 'comparisons' && <Comparisons data={data} />}
      </section>
    </main>
  </div>
</Base>

<style is:global>
  /* Layout vars — locally scoped to AssetPage. Not in vendor tokens.css.
     Match the literal pixels nav-rail / nav-masthead use in recipes.css.
     Promote to brand tokens when more pages need them. */
  :root {
    --rail-collapsed: 64px;
    --spine-width: 220px;
    --rail-expanded: 284px;     /* 64 + 220 */
    --masthead-height: 64px;
  }

  /* Push the binder right of the global nav-rail (64px) and identity
     spine (220px). The binder content column owns its own padding. */
  .binder {
    display: block;
    min-height: calc(100vh - var(--masthead-height));
    margin-left: var(--rail-expanded);
    background: var(--paper-deep);
  }

  .binder > .content {
    padding: 28px 32px 64px;
    min-width: 0;
    background: var(--paper-deep);
  }

  /* Mobile h1 fallback. Visually-hidden at <1100px (where the spine
     h1 disappears with the spine itself), display:none at ≥1100px
     (so we don't double up on h1s when the spine is visible). */
  .mobile-h1-fallback {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  @media (min-width: 1101px) {
    .mobile-h1-fallback { display: none; }
  }

  .stale-banner {
    margin: 0 0 18px;
    padding: 12px 18px;
    background: var(--paper);
    border-radius: 4px;
    box-shadow:
      inset 0 2px 4px rgba(40,30,18,0.08),
      inset 0 -1px 0 rgba(255,251,240,0.7);
    display: flex; align-items: baseline; gap: 16px;
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-mid);
  }
  .stale-banner .label { color: var(--ink); font-weight: 500; }
  .stale-banner .detail { color: var(--ink-mid); font-variant-numeric: tabular-nums; }

  .page { display: block; }

  /* ≤1100px: spine collapses to top stack, binder takes full width. */
  @media (max-width: 1100px) {
    .binder { margin-left: var(--rail-collapsed); }
    .binder > .content { padding: 20px 24px 64px; }
  }

  @media (max-width: 700px) {
    .binder { margin-left: 0; }
    .binder > .content { padding: 16px 16px 48px; }
  }
</style>
