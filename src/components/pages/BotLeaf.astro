---
import Base from '~/layouts/Base.astro';
import { assetBySlug, sectorBySlug, botBySlug } from '~/config/taxonomy';
export interface Props { sectorSlug: string; assetSlug: string; botSlug: string }
const { sectorSlug, assetSlug, botSlug } = Astro.props;
const sector = sectorBySlug(sectorSlug);
const asset = assetBySlug(assetSlug);
const bot = botBySlug(botSlug);
if (!sector || !asset || !bot || bot.assetSlug !== assetSlug) return Astro.redirect('/');
---
<Base title={`kujaku.ai — ${asset.name} · ${bot.name}`}>
  <section class="leaf-stage">
    <p class="crumb">
      <span>{sector.slug}</span><span class="sep">·</span>
      <span>{asset.slug}</span><span class="sep">·</span>
      <span>{bot.name} bot</span>
      <span class="mode-badge">paper mode</span>
    </p>

    <section class="hero-zone">
      <p class="eyebrow-lab">lifetime · v1.4 paper</p>
      <p class="hero-num">+$1,111.11</p>
      <p class="hero-meta">+11.11% since inception · 111 trades</p>
    </section>

    <section class="dense-strip-mobile">
      <div class="s">
        <span class="lab">portfolio</span>
        <span class="num">$1,111.11</span>
        <span class="meta">cash $1,111.11 · exp $11.11</span>
      </div>
      <div class="s">
        <span class="lab">win rate</span>
        <span class="num">11%</span>
        <span class="meta">111 won · 11 lost</span>
      </div>
      <div class="s">
        <span class="lab">last decision</span>
        <span class="num">1m ago</span>
        <span class="meta">11:11 mdt</span>
      </div>
    </section>

    <div class="leaf-shell">
      <aside class="tab-rail-desktop" role="tablist">
        <div class="rail-section">
          <button class="rail-tab leaf-tab is-active" data-panel="overview" role="tab"><span class="slash">/</span>overview</button>
          <button class="rail-tab leaf-tab" data-panel="live" role="tab" style="margin-top: 8px;"><span class="slash">/</span>live</button>
          <button class="rail-tab leaf-tab" data-panel="learning" role="tab" style="margin-top: 8px;"><span class="slash">/</span>learning</button>
        </div>
        <div class="rail-divider"></div>
        <div class="rail-stats">
          <div class="rs">
            <span class="lab">portfolio</span>
            <span class="num">$1,111.11</span>
            <span class="meta">cash $1,111.11 · exp $11.11</span>
          </div>
          <div class="rs">
            <span class="lab">win rate</span>
            <span class="num">11%</span>
            <span class="meta">111 won · 11 lost</span>
          </div>
          <div class="rs">
            <span class="lab">last decision</span>
            <span class="num">1m ago</span>
            <span class="meta">11:11 mdt · window active</span>
          </div>
        </div>
      </aside>

      <div>
        <div class="leaf-tab-row-mobile" role="tablist">
          <button class="leaf-tab-pressed leaf-tab is-active" data-panel="overview" role="tab">Overview</button>
          <button class="leaf-tab-pressed leaf-tab" data-panel="live" role="tab">Live</button>
          <button class="leaf-tab-pressed leaf-tab" data-panel="learning" role="tab">Learning</button>
        </div>

        <section class="leaf-panel is-active" data-panel="overview"></section>
        <section class="leaf-panel" data-panel="live"></section>
        <section class="leaf-panel" data-panel="learning"></section>
      </div>
    </div>
  </section>
</Base>

<style>
  .leaf-stage { padding: 36px 56px 96px; max-width: 1240px; margin: 0 auto; }

  .crumb { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--ink-mid); margin: 0 0 28px;
    display: flex; align-items: center; gap: 14px; }
  .crumb .sep { color: var(--ink-faint); }
  .mode-badge { display: inline-block; font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-pale);
    padding: 3px 8px; border: 1px solid var(--ink-pale); border-radius: 2px;
    margin-left: auto; }

  .hero-zone { padding: 18px 0 36px;
    border-bottom: 1px solid var(--ink-faint); margin-bottom: 0; }
  .hero-zone .eyebrow-lab { font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-mid);
    margin: 0 0 14px; font-weight: 500; }
  .hero-zone .hero-num { font-family: var(--font-display); font-style: italic;
    font-weight: 300; font-size: 72px; color: var(--ink);
    letter-spacing: -0.02em; line-height: 1; margin: 0;
    font-variant-numeric: tabular-nums; }
  .hero-zone .hero-meta { font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-mid);
    margin: 16px 0 0; font-variant-numeric: tabular-nums; }

  .leaf-shell { display: grid; grid-template-columns: 220px 1fr; gap: 36px;
    margin-top: 32px; align-items: start; }

  .tab-rail-desktop {
    position: sticky; top: 24px;
    display: flex; flex-direction: column; gap: 8px;
    padding-right: 28px;
    border-right: 1px solid var(--ink-faint);
  }

  .rail-section + .rail-divider { margin: 22px 0 18px; height: 1px;
    background: var(--ink-faint); }

  .rail-tab { padding: 12px 16px; background: var(--paper); border: 0;
    border-left: 2px solid transparent; cursor: pointer;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--ink-mid); border-radius: 2px;
    text-align: left; display: flex; align-items: center; gap: 10px;
    box-shadow:
      inset 0 1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.5),
      0 2px 6px rgba(40,30,18,0.05),
      0 6px 14px rgba(40,30,18,0.04);
    transition: box-shadow 240ms var(--ease-out),
      background 240ms var(--ease-out); }
  .rail-tab .slash { color: var(--ink-pale); }
  .rail-tab:hover { color: var(--ink); }
  .rail-tab:hover .slash { color: var(--ink); }
  .rail-tab.is-active { background: var(--paper-deep); color: var(--ink); font-weight: 500;
    border-left-color: var(--ink);
    box-shadow:
      inset 0 2px 4px rgba(40,30,18,0.10),
      inset 0 -1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.7); }
  .rail-tab.is-active .slash { color: var(--ink-mid); }

  .rail-stats { display: flex; flex-direction: column; gap: 18px; padding: 0 4px; }
  .rail-stats .rs { display: flex; flex-direction: column; gap: 4px; }
  .rail-stats .lab { font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-mid);
    font-weight: 500; }
  .rail-stats .num { font-family: var(--font-mono); font-size: 17px;
    color: var(--ink); font-weight: 500; font-variant-numeric: tabular-nums;
    letter-spacing: -0.005em; }
  .rail-stats .meta { font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.06em; color: var(--ink-mid); margin-top: 2px;
    font-variant-numeric: tabular-nums; }

  .leaf-tab-row-mobile { display: none; justify-content: center; gap: 10px;
    margin: 0 auto 28px; flex-wrap: wrap; padding: 0; }
  .leaf-tab-pressed { padding: 14px 28px; min-width: 130px;
    background: var(--paper); border: 0; cursor: pointer;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--ink-mid); border-radius: 2px;
    box-shadow:
      inset 0 1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.5),
      0 2px 6px rgba(40,30,18,0.06),
      0 8px 16px rgba(40,30,18,0.05);
    transition: box-shadow 240ms var(--ease-out),
      background 240ms var(--ease-out); }
  .leaf-tab-pressed:hover { color: var(--ink); }
  .leaf-tab-pressed.is-active { background: var(--paper-deep);
    color: var(--ink); font-weight: 500;
    box-shadow:
      inset 0 2px 4px rgba(40,30,18,0.10),
      inset 0 -1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.7); }

  .dense-strip-mobile { display: none; grid-template-columns: repeat(3, 1fr); gap: 0;
    border-top: 1px solid var(--ink-faint); border-bottom: 1px solid var(--ink-faint);
    margin-top: 24px; }
  .dense-strip-mobile .s { padding: 16px 18px; border-right: 1px solid var(--ink-faint);
    display: flex; flex-direction: column; gap: 4px; }
  .dense-strip-mobile .s:first-child { padding-left: 0; }
  .dense-strip-mobile .s:last-child { border-right: 0; padding-right: 0; }
  .dense-strip-mobile .lab { font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-mid); }
  .dense-strip-mobile .num { font-family: var(--font-mono); font-size: 18px;
    color: var(--ink); font-weight: 500; font-variant-numeric: tabular-nums; }
  .dense-strip-mobile .meta { font-family: var(--font-mono); font-size: 10px;
    color: var(--ink-mid); letter-spacing: 0.06em; font-variant-numeric: tabular-nums; }

  @media (max-width: 899px) {
    .leaf-shell { grid-template-columns: 1fr; gap: 0; }
    .tab-rail-desktop { display: none; }
    .leaf-tab-row-mobile { display: flex; }
    .dense-strip-mobile { display: grid; }
  }
  @media (max-width: 480px) {
    .leaf-stage { padding: 28px 20px 64px; }
    .leaf-tab-pressed { min-width: 110px; padding: 12px 18px; font-size: 10px;
      letter-spacing: 0.16em; }
    .hero-zone .hero-num { font-size: 48px; }
    .dense-strip-mobile { grid-template-columns: 1fr; }
    .dense-strip-mobile .s { border-right: 0; border-bottom: 1px solid var(--ink-faint);
      padding-left: 0; }
    .dense-strip-mobile .s:last-child { border-bottom: 0; }
  }

  .leaf-panel { display: none; }
  .leaf-panel.is-active { display: block; }
</style>

<script>
  (function () {
    const tabs = document.querySelectorAll('.leaf-tab');
    const panels = document.querySelectorAll('.leaf-panel');
    if (!tabs.length) return;
    tabs.forEach(t => t.addEventListener('click', () => {
      const target = (t as HTMLElement).dataset.panel;
      tabs.forEach(x => x.classList.toggle('is-active', (x as HTMLElement).dataset.panel === target));
      panels.forEach(x => x.classList.toggle('is-active', (x as HTMLElement).dataset.panel === target));
    }));
  })();
</script>
