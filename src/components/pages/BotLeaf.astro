---
import Base from '~/layouts/Base.astro';
import { assetBySlug, sectorBySlug, botBySlug } from '~/config/taxonomy';
export interface Props { sectorSlug: string; assetSlug: string; botSlug: string }
const { sectorSlug, assetSlug, botSlug } = Astro.props;
const sector = sectorBySlug(sectorSlug);
const asset = assetBySlug(assetSlug);
const bot = botBySlug(botSlug);
if (!sector || !asset || !bot || bot.assetSlug !== assetSlug) return Astro.redirect('/');
---
<Base title={`kujaku.ai — ${asset.name} · ${bot.name}`}>
  <section class="canvas">
    <h1 class="page-title">{asset.slug} · {bot.name} bot</h1>
    <p class="leaf-placeholder">placeholder — bot content will render here</p>
  </section>
</Base>

<style>
  .canvas {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: calc(100vh - 48px); gap: 0;
  }
  .page-title {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: var(--text-5xl, 48px); color: var(--ink);
    margin: 0; letter-spacing: -0.02em;
  }
  .leaf-placeholder {
    font-family: var(--font-mono); font-size: var(--text-sm, 14px);
    color: var(--ink-pale); letter-spacing: 0.04em;
    text-align: center; margin: 32px 0;
  }
</style>
