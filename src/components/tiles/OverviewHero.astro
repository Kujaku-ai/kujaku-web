---
// Overview hero block — ceremonial Sentient italic price + change line.
// Server-rendered from mock data; no polling in Phase 2.
//
// Layout: full-name + ticker-symbol stacked at the top, price + change
// pinned to the bottom (so the tile keeps a stable hero rhythm even
// when the right column's mini-chart drives the row height).

import type { AssetData } from '~/lib/types/asset';

export interface Props { data: AssetData }
const { data } = Astro.props;

function fmtPrice(n: number): string {
  return n.toLocaleString('en-US', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
}
function fmtPct(n: number): string {
  const sign = n > 0 ? '+' : '';
  return sign + n.toFixed(2) + '%';
}
function fmtAbs(n: number): string {
  const sign = n > 0 ? '+' : n < 0 ? '−' : '';
  return sign + '$' + fmtPrice(Math.abs(n));
}
function dirGlyph(dir: 'up' | 'down' | 'flat' | 'side'): string {
  if (dir === 'up')   return '↑';
  if (dir === 'down') return '↓';
  if (dir === 'side') return '↔';
  return '→';
}

const dc = data.dailyChange;
---

<section class="hero-tile">
  <div class="hero-id">
    <h1 class="full-name">{data.fullName}</h1>
    <p class="ticker-sym">{data.symbol}</p>
  </div>
  <div class="hero-num">
    <p class="price">${fmtPrice(data.currentPrice)}</p>
    <p class="change">
      <span class="glyph">{dirGlyph(dc.direction)}</span>
      <span>{fmtPct(dc.pct)}</span>
      <span class="dot">·</span>
      <span>{fmtAbs(dc.abs)}</span>
      <span class="dot">·</span>
      <span>24H</span>
    </p>
  </div>
</section>

<style>
  .hero-tile {
    padding: 28px 32px;
    background: var(--paper);
    border-radius: 4px;
    box-shadow:
      inset 0 1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.5),
      0 4px 12px rgba(40,30,18,0.05);
    display: flex; flex-direction: column; justify-content: space-between;
    gap: 28px;
    min-height: 200px;
  }
  .hero-id { display: flex; flex-direction: column; gap: 6px; }
  .full-name {
    font-family: var(--font-display); font-style: italic; font-weight: 300;
    font-size: 32px; line-height: 1.05; letter-spacing: -0.02em;
    color: var(--ink); margin: 0;
  }
  .ticker-sym {
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-mid); margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .hero-num { display: flex; flex-direction: column; gap: 6px; }
  .price {
    /* ceremonial Sentient italic — ONE per page, on the Overview hero */
    font-family: var(--font-display); font-style: italic; font-weight: 300;
    font-size: 48px; line-height: 1; letter-spacing: -0.02em;
    color: var(--ink); margin: 0;
    font-variant-numeric: tabular-nums;
  }
  .change {
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-mid); margin: 0;
    font-variant-numeric: tabular-nums;
    display: inline-flex; align-items: baseline; gap: 8px; flex-wrap: wrap;
  }
  .change .glyph {
    font-family: var(--font-mono);
    font-size: 13px; color: var(--ink); margin-right: 2px;
  }
  .change .dot { color: var(--ink-faint); }

  @media (max-width: 1100px) {
    .hero-tile { min-height: 0; padding: 24px 26px; gap: 22px; }
    .price { font-size: 42px; }
  }
  @media (max-width: 700px) {
    .hero-tile { padding: 20px 22px; gap: 18px; }
    .full-name { font-size: 26px; }
    .price { font-size: 32px; }
    .change { font-size: 10px; letter-spacing: 0.08em; }
    .change .glyph { font-size: 11px; }
  }
</style>
