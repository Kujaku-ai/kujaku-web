---
// News feature tile. Synthesized multi-source story. --paper-deep
// background distinguishes from primaries (no red on the eyebrow —
// the surface color does the differentiation work). Same .is-hoverable
// affordance as the primary tile.
//
// Sort metadata mirrored as data-attrs for the section sort island.

import type { NewsFeature as NewsFeatureItem } from '~/lib/types/asset';

export interface Props {
  item: NewsFeatureItem;
  isLead?: boolean;
}
const { item, isLead = false } = Astro.props;

function fmtTs(iso: string): string {
  const d = new Date(iso);
  const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const day = d.getUTCDate();
  const mon = months[d.getUTCMonth()];
  const h = String(d.getUTCHours()).padStart(2, '0');
  const m = String(d.getUTCMinutes()).padStart(2, '0');
  return `${day} ${mon} · ${h}:${m}`;
}
function fmtCount(n: number): string {
  if (n < 1000) return String(n);
  if (n < 10000) return (n / 1000).toFixed(1) + 'k';
  return Math.round(n / 1000) + 'k';
}

const likes = item.likes ?? 0;
const popularity = item.popularity ?? 0;
const sources = item.sources;
const sourcesTitle = sources.join(', ');
const tsMs = Date.parse(item.ts);
---

<article
  class={`news-feature is-hoverable${isLead ? ' is-lead' : ''}`}
  data-ts={tsMs}
  data-likes={likes}
  data-popularity={popularity}
>
  <header class="eyebrow">
    <span class="tag">FEATURE · SYNTHESIZED</span>
    <span class="ts">{fmtTs(item.ts)}</span>
  </header>

  <h3 class="headline">{item.headline}</h3>

  <p class="excerpt">{item.excerpt}</p>

  <footer class="metrics">
    <span class="metric" aria-label={`${likes} likes`}>
      <svg class="icon" viewBox="0 0 24 24" width="12" height="12" fill="none"
           stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <span class="num">{fmtCount(likes)}</span>
    </span>
    <span class="metric" aria-label={`${popularity} reads`}>
      <svg class="icon" viewBox="0 0 24 24" width="12" height="12" fill="none"
           stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
      <span class="num">{fmtCount(popularity)}</span>
    </span>
    <span
      class="metric"
      title={sourcesTitle}
      aria-label={`${sources.length} sources: ${sourcesTitle}`}
    >
      <svg class="icon" viewBox="0 0 24 24" width="12" height="12" fill="none"
           stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      <span class="num">{sources.length}</span>
    </span>
  </footer>
</article>

<style>
  .news-feature {
    background: var(--paper-deep);
    border-radius: 4px;
    padding: 18px 20px 16px;
    box-shadow:
      inset 0 1px 0 rgba(255,251,240,0.5),
      0 1px 0 rgba(255,251,240,0.3),
      0 4px 12px rgba(40,30,18,0.05);
    display: flex; flex-direction: column;
    min-height: 200px;
  }

  .eyebrow {
    display: flex; flex-wrap: nowrap; align-items: baseline;
    justify-content: space-between; gap: 12px;
    margin: 0 0 10px;
    font-family: var(--font-mono); font-size: 9px; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
  }
  /* `FEATURE · SYNTHESIZED` is --ink, not red — paper-deep bg does
     the differentiation work. */
  .eyebrow .tag { color: var(--ink); white-space: nowrap; }
  .eyebrow .ts {
    color: var(--ink-mid); white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .headline {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: 17px; line-height: 1.25; color: var(--ink);
    margin: 0 0 10px; letter-spacing: -0.005em;
  }
  .news-feature.is-lead .headline { font-size: 20px; line-height: 1.2; }

  .excerpt {
    font-family: var(--font-body); font-size: 13px; line-height: 1.55;
    color: var(--ink-soft); margin: 0;
  }

  .metrics {
    margin-top: auto;
    padding-top: 14px;
    display: flex; align-items: center; gap: 18px;
    color: var(--ink);
  }
  .metric {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink); font-variant-numeric: tabular-nums;
  }
  .metric .icon { flex: 0 0 12px; color: var(--ink-mid); }
  /* The sources metric uses native title= for the tooltip; cursor:
     help signals to the reader that hover reveals more. */
  .metric[title] { cursor: help; }

  @media (max-width: 700px) {
    .news-feature { min-height: 0; padding: 16px 18px 14px; }
    .news-feature.is-lead .headline { font-size: 18px; }
    .headline { font-size: 16px; }
  }
</style>
