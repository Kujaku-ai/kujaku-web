---
// Chart analyst commentary — editorial card with weekly review +
// recent notes. BTC has the full mock report (from data.analyst);
// quantum tickers ship without an `analyst` field and render the
// "First report incoming" empty state.
//
// Real reports format themselves in Phase 8+ when the analyst service
// ships. The structure here matches what that service will return.

import type { AssetData } from '~/lib/types/asset';

export interface Props { data: AssetData }
const { data } = Astro.props;

function fmtDateRangeHeader(rangeLabel: string, reportTs: string): string {
  const d = new Date(reportTs);
  const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const day = d.getUTCDate();
  const mon = months[d.getUTCMonth()];
  const yr  = d.getUTCFullYear();
  const h = String(d.getUTCHours()).padStart(2, '0');
  const m = String(d.getUTCMinutes()).padStart(2, '0');
  return `${rangeLabel.toUpperCase()} · ${day} ${mon} ${yr} · ${h}:${m} UTC`;
}

function fmtNoteTs(iso: string): string {
  const d = new Date(iso);
  const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const day = d.getUTCDate();
  const mon = months[d.getUTCMonth()];
  const h = String(d.getUTCHours()).padStart(2, '0');
  const m = String(d.getUTCMinutes()).padStart(2, '0');
  return `${day} ${mon} · ${h}:${m}`;
}

const a = data.analyst;
---

<section class={`commentary-card${a ? '' : ' is-empty'}`}>
  <p class="card-eyebrow">chart analyst commentary <span class="jp">解説</span></p>

  {a ? (
    <>
      <p class="date-header">{fmtDateRangeHeader(a.rangeLabel, a.reportTs)}</p>
      {/* Card-level heading — h3 to fit the spec hierarchy
          (h1 page → h2 tab → h3 card). */}
      <h3 class="title">{a.title}</h3>

      <div class="body">
        {a.body.map((para) => <p>{para}</p>)}
      </div>

      <hr class="divider" />

      <div class="sub">
        <p class="sub-eyebrow">key observations</p>
        <ul class="observations">
          {a.observations.map((o) => <li>{o}</li>)}
        </ul>
      </div>

      <div class="sub">
        <p class="sub-eyebrow">outlook</p>
        <p class="outlook">{a.outlook}</p>
      </div>

      <hr class="divider" />

      <div class="sub">
        <p class="sub-eyebrow">recent notes</p>
        <ul class="notes">
          {a.recentNotes.map((n) => (
            <li>
              <span class="ts">{fmtNoteTs(n.ts)}</span>
              <span class="text">{n.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </>
  ) : (
    <div class="empty-state">
      <p class="empty-headline">First report incoming</p>
      <p class="empty-body">
        The chart analyst hasn't published for {data.fullName} yet.
        Reports refresh on a weekly cadence once the analyst service
        is online.
      </p>
    </div>
  )}
</section>

<style>
  .commentary-card {
    padding: 22px 28px 26px;
    background: var(--paper);
    border-radius: 4px;
    box-shadow:
      inset 0 1px 0 rgba(255,251,240,0.7),
      0 1px 0 rgba(255,251,240,0.5),
      0 4px 12px rgba(40,30,18,0.05);
  }

  .card-eyebrow {
    font-family: var(--font-mono); font-size: 9px; font-weight: 500;
    letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--ink-mid); margin: 0 0 14px;
    display: flex; align-items: baseline; gap: 10px;
  }
  .card-eyebrow .jp {
    font-family: var(--font-jp); font-size: 13px;
    letter-spacing: 0.04em; text-transform: none;
    color: var(--red); font-weight: 400;
  }

  .date-header {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-mid); margin: 0 0 14px;
    font-variant-numeric: tabular-nums;
  }

  .title {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: 28px; line-height: 1.2; letter-spacing: -0.01em;
    color: var(--ink); margin: 0 0 18px;
    max-width: 60ch;
  }

  .body p {
    font-family: var(--font-body); font-size: 15px; line-height: 1.7;
    color: var(--ink-soft); margin: 0 0 14px;
    max-width: 70ch;
  }
  .body p:last-child { margin-bottom: 0; }

  .divider {
    border: 0; border-top: 1px solid var(--ink-faint);
    margin: 22px 0;
  }

  .sub { margin: 0 0 22px; }
  .sub:last-child { margin-bottom: 0; }
  .sub-eyebrow {
    font-family: var(--font-mono); font-size: 9px; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-mid); margin: 0 0 10px;
  }

  .observations {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
    max-width: 70ch;
  }
  .observations li {
    font-family: var(--font-body); font-size: 14px; line-height: 1.55;
    color: var(--ink-soft); padding-left: 16px; position: relative;
  }
  .observations li::before {
    content: '→';
    font-family: var(--font-mono); color: var(--ink-pale);
    position: absolute; left: 0; top: 1px;
  }

  .outlook {
    font-family: var(--font-body); font-size: 14px; line-height: 1.6;
    color: var(--ink-soft); margin: 0;
    max-width: 70ch;
  }

  .notes {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column;
  }
  .notes li {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid var(--ink-faint);
  }
  .notes li:last-child { border-bottom: 0; }
  .notes li:first-child { padding-top: 0; }
  .notes .ts {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-mid); font-variant-numeric: tabular-nums;
  }
  .notes .text {
    font-family: var(--font-body); font-size: 13px; line-height: 1.5;
    color: var(--ink-soft);
  }

  /* Empty state — italic Sentient headline centered, brief subline. */
  .empty-state {
    padding: 36px 0 28px;
    display: flex; flex-direction: column; align-items: center;
    text-align: center; gap: 12px;
  }
  .empty-headline {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: 24px; color: var(--ink); margin: 0;
    letter-spacing: -0.01em; line-height: 1.2;
  }
  .empty-body {
    font-family: var(--font-body); font-size: 13px; line-height: 1.55;
    color: var(--ink-mid); margin: 0;
    max-width: 48ch;
  }

  @media (max-width: 700px) {
    .commentary-card { padding: 20px 22px; }
    .title { font-size: 22px; }
    .body p, .observations li, .outlook { font-size: 14px; }
    .notes li { grid-template-columns: 84px 1fr; gap: 12px; }
    .notes .ts { font-size: 9px; letter-spacing: 0.14em; }
  }
</style>
