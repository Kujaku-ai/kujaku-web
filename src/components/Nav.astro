---
import Palette from '~/components/Palette.astro';
export interface Props { user?: string; }
const { user } = Astro.props;
---
<div class="nav-composition">
  <aside class="nav-rail is-overlay">
    <div class="mark">
      <img class="svg" src="/brand/logo-mark-red-pressed.svg" alt="Kujaku" />
      <svg class="lockup" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 127 63.5">
        <defs><filter id="press" x="-10%" y="-10%" width="120%" height="120%"><feGaussianBlur in="SourceAlpha" stdDeviation="1.5"/><feOffset dx="0" dy="2"/><feComposite in2="SourceAlpha" operator="arithmetic" k2="-1" k3="1" result="shadowDiff"/><feFlood flood-color="#28201e" flood-opacity="0.7"/><feComposite in2="shadowDiff" operator="in" result="innerShadow"/><feMerge><feMergeNode in="SourceGraphic"/><feMergeNode in="innerShadow"/></feMerge></filter></defs>
        <g transform="translate(-30.511761,-24.280848)"><g transform="translate(6.5277492)"><g transform="matrix(1.3007991,0,0,1.3007991,-24.729646,-29.193993)">
          <g transform="matrix(0.58238742,0,0,0.58238742,15.7223,15.710075)" filter="url(#press)">
            <path fill="#c8331e" d="m 51.670794,74.225678 c -6.708605,0 -12.20433,5.193709 -12.685721,11.779452 -0.0379,0.518461 0.387803,0.936692 0.906271,0.97459 4.963176,0.362794 9.136077,3.573352 10.890777,8.004789 0.484366,1.22325 0.686409,1.8348 0.888673,1.834798 0.202265,2e-6 0.404308,-0.611548 0.888674,-1.834798 1.7547,-4.431437 5.927602,-7.641995 10.890777,-8.004789 0.518469,-0.0379 0.944171,-0.456129 0.906272,-0.97459 C 63.875124,79.419386 58.3794,74.225678 51.670794,74.225678 Z"/>
            <path fill="#c8331e" d="m 66.934653,89.489536 c -6.708606,0 -12.20433,5.193707 -12.685722,11.779444 -0.0379,0.51846 0.387803,0.93669 0.906271,0.97459 4.963176,0.3628 9.136077,3.57335 10.890778,8.00479 0.484365,1.22325 0.686409,1.8348 0.888673,1.8348 0.202264,0 0.404308,-0.61155 0.888673,-1.8348 1.7547,-4.43144 5.927602,-7.64199 10.890778,-8.00479 0.518468,-0.0379 0.94417,-0.45613 0.906271,-0.97459 C 79.138983,94.683242 73.643259,89.489536 66.934653,89.489536 Z"/>
            <path fill="#c8331e" d="m 66.934653,58.96182 c -6.708606,0 -12.20433,5.193707 -12.685722,11.779445 -0.0379,0.518461 0.387803,0.936691 0.906271,0.97459 4.963176,0.362794 9.136077,3.573351 10.890778,8.004789 0.484365,1.22325 0.686409,1.834799 0.888673,1.834797 0.202264,2e-6 0.404308,-0.611547 0.888673,-1.834797 1.7547,-4.431438 5.927602,-7.641995 10.890778,-8.004789 0.518468,-0.0379 0.94417,-0.456129 0.906271,-0.97459 C 79.138983,64.155526 73.643259,58.96182 66.934653,58.96182 Z"/>
          </g>
          <text x="65.583397" y="70.617149" font-family="Sentient" font-size="20.3994" fill="#1a1815">Kujaku</text>
          <text x="97.768898" y="75.870705" font-family="Sentient" font-size="4.54443" letter-spacing="0.177271" fill="#1a1815">INVESTMENTS</text>
        </g></g></g>
      </svg>
    </div>
    <nav class="items">
      <div class="nav-section">
        <p class="label">System</p>
        <a class="nav-item is-active" href="/"><span class="slash">/</span><span class="label">home</span></a>
      </div>
    </nav>
    <div class="footer">
      <p>kujaku.ai</p>
      <p>cycle 7</p>
      <p>app shell</p>
    </div>
  </aside>
  <main>
    <header class="nav-masthead is-centered-ticker">
      <button class="palette-trigger" type="button" aria-label="Open search">/</button>
      <div class="ticker-viewport">
        <div class="ticker-track">
          <div class="ticker-block"><span class="symbol">BTC</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">SPX</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">NVDA</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">AAPL</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">TSLA</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">GOOG</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">MSFT</span><span class="delta">—</span><span class="price">—</span></div>
          <!-- doubled for seamless 60s marquee loop per brand ticker contract -->
          <div class="ticker-block"><span class="symbol">BTC</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">SPX</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">NVDA</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">AAPL</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">TSLA</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">GOOG</span><span class="delta">—</span><span class="price">—</span></div>
          <div class="ticker-block"><span class="symbol">MSFT</span><span class="delta">—</span><span class="price">—</span></div>
        </div>
      </div>
      {user && <span class="user">{user}</span>}
    </header>
    <Palette />
    <slot />
  </main>
</div>
