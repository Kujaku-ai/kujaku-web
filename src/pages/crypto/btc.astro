---
import Base from '~/layouts/Base.astro';
import { assetBySlug, sectorBySlug } from '~/config/taxonomy';
const asset = assetBySlug('btc');
const sector = sectorBySlug('crypto');
if (!asset || !sector) return Astro.redirect('/');
---
<Base title={`kujaku.ai — ${asset.name}`}>
  <main style="padding: 80px 32px 120px;">
    <header style="max-width: 960px; margin: 0 auto 80px; display: flex; flex-direction: column; gap: 16px;">
      <a href={`/${sector.slug}`} style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-mid, #7A736A); text-decoration: none;">← {sector.name}</a>
      <div style="display: flex; align-items: baseline; gap: 20px; flex-wrap: wrap;">
        <div style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-mid, #7A736A);">{asset.name}</div>
        <h1 style="font-family: var(--font-display, 'Sentient', Georgia, serif); font-style: italic; font-weight: 400; font-size: clamp(40px, 6vw, 64px); margin: 0; letter-spacing: -0.02em;">{asset.fullName}</h1>
      </div>
    </header>
    <section style="max-width: 720px; margin: 0 auto; text-align: center; padding: 60px 0;">
      <div style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-pale, #B5AE9F);">live data panel — coming soon</div>
    </section>
  </main>
</Base>
