---
import Base from '~/layouts/Base.astro';
import AssetGrid from '~/components/AssetGrid.astro';
import { sectorBySlug } from '~/config/taxonomy';
const sector = sectorBySlug('crypto');
if (!sector) return Astro.redirect('/');
---
<Base title={`kujaku.ai — ${sector.name}`}>
  <main style="padding: 80px 32px 120px;">
    <header style="max-width: 960px; margin: 0 auto 60px; display: flex; flex-direction: column; gap: 16px;">
      <a href="/" style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-mid, #7A736A); text-decoration: none;">← kujaku.ai</a>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        {sector.kanji && <div class="eyebrow is-gold" style="font-size: 14px;">{sector.kanji}</div>}
        <h1 style="font-family: var(--font-display, 'Sentient', Georgia, serif); font-style: italic; font-weight: 400; font-size: clamp(40px, 6vw, 64px); margin: 0; letter-spacing: -0.02em;">{sector.name}</h1>
        {sector.tagline && <p style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-mid, #7A736A); margin: 0;">{sector.tagline}</p>}
      </div>
    </header>
    <AssetGrid sectorSlug="crypto" />
  </main>
</Base>
