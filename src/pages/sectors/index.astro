---
import Base from '~/layouts/Base.astro';
import { visibleSectors } from '~/config/taxonomy';
const sectorsList = visibleSectors();
---
<Base title="kujaku.ai — sectors">
  <section class="canvas">
    <h1 class="page-title">sectors</h1>
    <div class="buttons">
      {sectorsList.map((sector) => (
        <a class="btn is-route" href={`/${sector.slug}`}>{sector.slug}</a>
      ))}
    </div>
  </section>
</Base>

<style>
  .canvas {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: calc(100vh - 48px); gap: 40px;
  }
  .page-title {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: var(--text-5xl, 48px); color: var(--ink);
    margin: 0; letter-spacing: -0.02em;
  }
  .buttons { display: flex; flex-direction: column; gap: 16px; align-items: center; }
  @media (max-width: 767px) {
    .page-title { font-size: var(--text-3xl, 30px); }
    .buttons { gap: 12px; }
  }
</style>
