---
import Base from '~/layouts/Base.astro';
const failed = Astro.url.searchParams.get('e') === '1';
---
<Base title="kujaku.ai — sign in" hideNav={true}>
  <main style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <form method="POST" action="/api/login" style="width: 100%; max-width: 320px; display: flex; flex-direction: column; gap: 20px;">
      <div style="text-align: center; margin-bottom: 8px;">
        <div class="eyebrow is-gold">孔雀</div>
        <div style="font-family: var(--font-display, 'Sentient', Georgia, serif); font-style: italic; font-size: 28px; letter-spacing: -0.01em; margin-top: 8px;">kujaku.ai</div>
      </div>
      <label style="display: flex; flex-direction: column; gap: 6px;">
        <span style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-mid, #7A736A);">password</span>
        <input
          type="password"
          name="password"
          autocomplete="current-password"
          autofocus
          required
          style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 15px; padding: 10px 12px; border: 0.5px solid var(--ink-pale, #B5AE9F); background: transparent; outline: none; letter-spacing: 0.05em;"
        />
      </label>
      {failed && (
        <div style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--red-deep, #5a1a1a);">incorrect</div>
      )}
      <button
        type="submit"
        style="font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; padding: 10px 0; background: var(--ink, #1a1a1a); color: var(--paper, #f5f1e8); border: none; cursor: pointer;"
      >enter</button>
    </form>
  </main>
</Base>
