---
import Nav from '~/components/Nav.astro';
export interface Props {
  title?: string;
  hideNav?: boolean;
}
const { title = 'kujaku.ai', hideNav = false } = Astro.props;
const user = (Astro.locals as { user?: string }).user;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="/brand/fonts.css" />
    <link rel="stylesheet" href="/brand/tokens.css" />
    <link rel="stylesheet" href="/brand/textures.css" />
    <link rel="stylesheet" href="/brand/recipes.css" />
  </head>
  <body style="margin: 0; background: var(--paper, #f5f1e8); color: var(--ink, #1a1a1a);">
    {!hideNav && <Nav user={user} />}
    <slot />
  </body>
</html>
