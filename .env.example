# Required: JSON map of name -> bcrypt hash.
# Generate hashes with: node scripts/hash-password.mjs <plaintext>
# Single-quote the value AND backslash-escape every $ so dotenv-expand doesn't
# consume bcrypt's $2a$10$... markers as undefined variable references.
AUTH_USERS='{"XBurt":"\$2a\$10\$REPLACE_WITH_HASH","Shaker":"\$2a\$10\$REPLACE_WITH_HASH"}'

# Required: 64-char random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_RANDOM

# Optional: Discord webhook URL for login notifications.
# If unset, login still works, pings are silently skipped.
DISCORD_WEBHOOK_URL=
